# ── Trading environment ──────────────────────────────────────────
# "paper" = simulation, "live" = real MT5 execution
TRADING_ENVIRONMENT=paper

# ── MetaTrader 5 (Windows only, required for live mode) ──────────
MT5_TERMINAL_PATH=
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/trading_intelligence.sqlite3

# ── Risk parameters ──────────────────────────────────────────────
# MAX_DAILY_DRAWDOWN=0.05        # 5% max daily drawdown
# MAX_TOTAL_DRAWDOWN=0.15         # 15% max total drawdown
# MAX_POSITIONS=3                 # Max concurrent positions
# MAX_POSITIONS_PER_INSTRUMENT=1  # Max positions on one symbol
# DEFAULT_POSITION_SIZE=0.01      # Default lot size
# ATR_PERIOD=14                   # ATR period for dynamic sizing
# ATR_MULTIPLIER=1.5              # Stop-loss: ATR * multiplier
# CORRELATION_EXPOSURE_LIMIT=0.70 # Max correlation between positions
# VOLATILITY_KILL_SWITCH=3.0      # Halt if spread > 3x average

# ── Session times (UTC hours) ────────────────────────────────────
# SESSION_ASIAN_START=0
# SESSION_ASIAN_END=9
# SESSION_LONDON_START=8
# SESSION_LONDON_END=17
# SESSION_NY_START=13
# SESSION_NY_END=22

# ── Instruments ──────────────────────────────────────────────────
# INSTRUMENT_WHITELIST=["EURUSD","XAUUSD","GBPUSD"]
# INSTRUMENT_TIMEFRAMES=["M5","M15","H1","H4","D1"]

# ── Agent weights ────────────────────────────────────────────────
# SIGNAL_WEIGHT=40.0
# SESSION_WEIGHT=30.0
# NEWS_WEIGHT=30.0

# ── Consensus ────────────────────────────────────────────────────
# CONSENSUS_MINIMUM_SCORE=70.0    # Minimum combined score (0-100)
# CONSENSUS_MIN_CONFIDENCE=60.0   # Minimum signal confidence

# ── Learning ─────────────────────────────────────────────────────
# LEARNING_MIN_SAMPLE_SIZE=30     # Min trades before recommendations
# LEARNING_RECOMMENDATION_CONFIDENCE=0.80

# ── Polling ──────────────────────────────────────────────────────
# POLLING_INTERVAL_SECONDS=60

# ── Logging ──────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=text

# ── Paths ────────────────────────────────────────────────────────
# DATA_DIR=data
# ECONOMIC_CALENDAR_PATH=data/economic_calendar.csv
